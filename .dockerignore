# ---------------------------------------------------------------------------
# .dockerignore — keep the build context small and reproducible.
#
# MUST retain (do NOT add these):
#   mediascanmonitor/   pyproject.toml   uv.lock   README.md   LICENSE
#
# README.md and LICENSE are referenced by pyproject.toml ([project] readme /
# license).  The hatchling build fails without them.
# ---------------------------------------------------------------------------

# Version control
.git
.gitignore
.gitattributes

# Python bytecaches and build artefacts
__pycache__
*.py[cod]
*.egg-info/
.eggs/
dist/
build/

# Development virtual environment
.venv/
.python-version

# Databases and secret-key files (never include these in an image layer)
*.db
*.db-shm
*.db-wal
*.key

# Tests, docs, and CI configuration
tests/
docs/
.github/

# Legacy Bash artefacts (replaced by the Python app in this rewrite)
plex_monitor.sh
plex_monitor.conf
plex_token.txt.example

# Compose / tooling / editor state
docker-compose.yml
alembic.ini
CLAUDE.md
.env
.env.*
*.local
.idea/
.vscode/
.superpowers/
